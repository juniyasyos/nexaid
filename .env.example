APP_NAME=IAM
APP_ENV=local
APP_KEY=base64:G8w0qytVP8V+Mml5pYqm90R9m7AdfltGk1GCXMGq2qw=
APP_DEBUG=true

# ⚠️  CRITICAL: Update these URLs for each environment!
# These are used for:
# 1. Generating JWT token issuer (iss claim)
# 2. CORS and same-origin checks
# 3. Frontend API calls
# Examples:
#   - Local:      http://localhost:8010
#   - Docker:     http://127.0.0.1:8100
#   - Production: https://iam.example.com
APP_URL=http://192.168.1.9:8100
IAM_ISSUER=http://192.168.1.9:8100

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=iam
DB_USERNAME=juni
DB_PASSWORD=password
DB_PERSISTENT=false

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# MinIO S3 Configuration
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=password
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=data-center
AWS_URL=http://127.0.0.1:9090/data-center
AWS_ENDPOINT=http://127.0.0.1:9090
AWS_USE_PATH_STYLE_ENDPOINT=true
VITE_APP_NAME="${APP_NAME}"

# --- Panel Settings ---
# Customize panel identity and URL path.
PANEL_ID=panel
PANEL_PATH=panel
PANEL_NAME=Panel
# Optional version label shown in topbar (e.g. 1.0.0)
# PANEL_VERSION=

# --- Panel Theme Settings ---
# Primary brand color (hex or Filament palette via code). Example: #f59e0b
PANEL_THEME_PRIMARY=#f59e0b
# Optional additional semantic colors (hex). Leave blank to use defaults.
# PANEL_THEME_GRAY=
# PANEL_THEME_SUCCESS=
# PANEL_THEME_WARNING=
# PANEL_THEME_DANGER=
# PANEL_THEME_INFO=
# Default theme mode: system | light | dark
PANEL_THEME_MODE=system

# --- Branding (optional) ---
# PANEL_BRAND_NAME=Panel
# PANEL_BRAND_LOGO=/images/brand/logo-light.svg
# PANEL_BRAND_LOGO_DARK=/images/brand/logo-dark.svg
# PANEL_BRAND_LOGO_HEIGHT=1.5rem
# PANEL_BRAND_FAVICON=/favicon.ico

# --- IAM Admin Access Control ---
# Comma-separated list of emails allowed to access IAM admin panel
IAM_ADMIN_EMAILS=admin@gmail.com
# Access method: email, callback, both, either
IAM_ADMIN_ACCESS_METHOD=email
# Optional custom denied message
# IAM_ADMIN_DENIED_MESSAGE="Access denied. Only authorized IAM administrators can access this area."
# Optional redirect after denial (leave empty for 403 page)
# IAM_ADMIN_DENIED_REDIRECT=/

# Frontend Configuration
# FRONTEND_PORT=3100
# FRONTEND_HOST=localhost
# FRONTEND_URL=http://localhost:3100
# FRONTEND_HOST_PATTERN=/localhost/
IAM_JWT_SECRET=base64:G8w0qytVP8V+Mml5pYqm90R9m7AdfltGk1GCXMGq2qw=
IAM_ISSUER=http://127.0.0.1:8010
